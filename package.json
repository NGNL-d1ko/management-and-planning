{
  "name": "management-and-planning",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "framework": "React 18.2.0 (функциональные компоненты + хуки)",
  "build": "Vite 5.0.0",
  "routing": "React Router DOM 6.20.0",
  "UI": "React-Bootstrap 2.9.1 + Bootstrap 5.3.2",
  "icons": "React Icons 4.12.0",
  "auth": "Контекст + LocalStorage",
  "drag-and-drop": "@dnd-kit (core, sortable, utilities)",
  "calendar": "react-big-calendar + date-fns",
  "charts": "recharts",
  "forms": "Встроенные формы React",
  "dates": "date-fns",
  "scripts": {
    "dev": "vite --host localhost --port 5174 --strictPort",
    "build": "vite build",
    "build:web": "vite build",
    "build:electron": "vite build --mode electron",
    "build:local": "vite build --mode electron --env VITE_FORCE_LOCAL=true",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "npm run build:electron && electron .",
    "electron:local": "npm run build:local && electron .",
    "electron:pack": "npm run build:electron && electron-builder --config electron-builder.json",
    "electron:pack:local": "npm run build:local && electron-builder --config electron-builder.json --dir"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.105.1",
    "bootstrap": "^5.3.8",
    "date-fns": "^4.1.0",
    "react": "^19.2.0",
    "react-big-calendar": "^1.19.4",
    "react-bootstrap": "^2.10.10",
    "react-bootstrap-icons": "^1.11.6",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.10.0",
    "recharts": "^3.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4"
  }
}
